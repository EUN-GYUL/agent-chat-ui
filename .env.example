# Instructor Chat UI - LangGraph Configuration
# Uses API proxy pattern to avoid CORS issues

# Local development (API proxy)
NEXT_PUBLIC_API_URL=http://localhost:3003/api
NEXT_PUBLIC_ASSISTANT_ID=instructor_agent
LANGGRAPH_API_URL=http://localhost:2024

# Optional. Required for Agent Builder deployments.
NEXT_PUBLIC_AUTH_SCHEME=
# Do NOT prefix this with "NEXT_PUBLIC_" as we do not want this exposed in the client.
LANGSMITH_API_KEY=

# Production Configuration - Uncomment to use
# LANGGRAPH_API_URL="https://deepmathagent-....us.langgraph.app"
# NEXT_PUBLIC_API_URL="https://your-instructor-ui.vercel.app/api"
# LANGSMITH_API_KEY="lsv2_..."
